# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv/

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Local SQLite DB (dev only; prod is Postgres). Both the legacy `oversee.db`
# name and the current `trovis.db` are ignored.
oversee.db
oversee.db-journal
oversee.db-shm
oversee.db-wal
trovis.db
trovis.db-journal
trovis.db-shm
trovis.db-wal

# The OpenClaw plugin ships pre-compiled, so its dist/ is tracked even
# though the generic `dist/` rule above would otherwise hide it.
!oversee-openclaw-plugin/dist/
!oversee-openclaw-plugin/dist/**

# Local environment
.env
.env.local

# Vercel CLI deploys. Sub-projects have their own .gitignore for this;
# defend at the root in case someone ever runs `vercel` from here.
.vercel/

# Claude Code (per-user, not project)
.claude/
