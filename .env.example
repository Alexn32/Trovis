# Uncomment DATABASE_URL to use Postgres. Leave it commented to use the
# SQLite fallback at ./trovis.db (recommended for local development).
# DATABASE_URL=postgresql://user:password@host:5432/oversee

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional. When set, every endpoint except /health requires the matching
# X-Trovis-Api-Key (legacy X-Oversee-Api-Key also accepted) header. Leave unset locally for auth-free dev.
# TROVIS_INGEST_KEY=pick_any_long_random_string

# Stripe billing — gates paid plan upgrades (PUT /account/plan + the
# /billing/webhook receiver). Leave UNSET to disable upgrades entirely: the
# endpoint then fails closed (503) so nobody can self-upgrade for free. Set all
# of these (Stripe's own variable names — paste straight from the dashboard) to
# enable Checkout. Each price must be a recurring Price for that tier.
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_STARTER=price_...
# STRIPE_PRICE_PRO=price_...
# STRIPE_PRICE_ENTERPRISE=price_...

# Optional. Base URL the Stripe success/cancel redirects point back to. Falls
# back to the request's own origin when unset. (TROVIS_ / OVERSEE_ both work.)
# TROVIS_APP_URL=https://app.trovisai.com
