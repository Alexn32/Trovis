# Uncomment DATABASE_URL to use Postgres. Leave it commented to use the
# SQLite fallback at ./oversee.db (recommended for local development).
# DATABASE_URL=postgresql://user:password@host:5432/oversee

ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional. When set, every endpoint except /health requires the matching
# X-Oversee-Api-Key header. Leave unset locally for auth-free dev.
# OVERSEE_INGEST_KEY=pick_any_long_random_string
