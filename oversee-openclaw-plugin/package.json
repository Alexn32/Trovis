{
  "name": "@oversee/openclaw-plugin",
  "version": "0.1.0",
  "description": "Oversee Agent Management — automatic telemetry for OpenClaw agents",
  "type": "module",
  "openclaw": {
    "extensions": ["./dist/index.mjs"]
  },
  "scripts": {
    "build": "esbuild index.ts --outfile=dist/index.mjs --platform=node --format=esm --bundle --external:openclaw --external:openclaw/* --external:@sinclair/typebox"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.52.0",
    "@opentelemetry/resources": "^1.25.0",
    "@opentelemetry/semantic-conventions": "^1.25.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0"
  },
  "license": "MIT"
}
